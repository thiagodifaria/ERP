# Production-like template. Keep values empty until injected by a secret manager or CI/CD.
# Do not reuse .env.example defaults in a corporate environment.

ERP_ENV=production
ERP_ALLOW_BOOTSTRAP_TENANT_FALLBACK=false
ERP_TZ=UTC
COMPOSE_PROJECT_NAME=erp
ERP_AUTH_ENFORCEMENT=enforced
ERP_JWT_HS256_SECRET=
ERP_JWT_AUDIENCE=erp-api
ERP_INTERNAL_SERVICE_TOKEN=
ERP_OPENFGA_ENFORCEMENT=true

# Only the gateway/edge should be published by the corporate-like compose overlay.
GATEWAY_HTTP_PORT=
EDGE_HTTP_PORT=

# Infrastructure secrets.
ERP_POSTGRES_DB=erp
ERP_POSTGRES_USER=
ERP_POSTGRES_PASSWORD=
KEYCLOAK_ADMIN_USER=
KEYCLOAK_ADMIN_PASSWORD=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# Identity and authorization.
KEYCLOAK_REALM=
KEYCLOAK_IDENTITY_CLIENT_ID=
IDENTITY_PROVIDER_DRIVER=keycloak
IDENTITY_AUTHORIZATION_DRIVER=openfga
IDENTITY_BOOTSTRAP_PASSWORD=
IDENTITY_EXPOSE_PASSWORD_RECOVERY_TOKEN=false
IDENTITY_MFA_ISSUER=ERP
KEYCLOAK_BASE_URL=http://service-keycloak:8080
OPENFGA_BASE_URL=http://service-openfga:8080
OPENFGA_STORE_NAME=
OPENFGA_STORE_ID=
OPENFGA_AUTHORIZATION_MODEL_ID=

# Internal API trust. Tokens should be short-lived service-account JWTs.
INTERNAL_SERVICE_TOKEN_ISSUER=
INTERNAL_SERVICE_TOKEN_AUDIENCE=
INTERNAL_SERVICE_TOKEN_JWKS_URL=
INTERNAL_SERVICE_TOKEN_TTL_SECONDS=300

# Document and webhook signing secrets.
DOCUMENTS_ACCESS_TOKEN_SECRET=
WEBHOOK_HUB_OUTBOUND_SIGNING_SECRET=

# Provider credentials.
CRM_CNPJ_PROVIDER_TOKEN=
CRM_CONECTA_CNPJ_API_KEY=
BILLING_ASAAS_API_KEY=
BILLING_STRIPE_SECRET_KEY=
BILLING_MERCADO_PAGO_ACCESS_TOKEN=
DOCUMENTS_CLICKSIGN_API_KEY=
DOCUMENTS_DOCUSIGN_ACCESS_TOKEN=
ENGAGEMENT_RESEND_API_KEY=
ENGAGEMENT_WHATSAPP_ACCESS_TOKEN=
ENGAGEMENT_TELEGRAM_BOT_TOKEN=
ENGAGEMENT_META_ADS_ACCESS_TOKEN=

# Internal URLs.
EDGE_IDENTITY_BASE_URL=http://identity:8080
EDGE_CRM_BASE_URL=http://crm:8083
EDGE_WORKFLOW_CONTROL_BASE_URL=http://workflow-control:8084
EDGE_WORKFLOW_RUNTIME_BASE_URL=http://workflow-runtime:8085
EDGE_ANALYTICS_BASE_URL=http://analytics:8086
EDGE_WEBHOOK_HUB_BASE_URL=http://webhook-hub:8082
EDGE_SALES_BASE_URL=http://sales:8087
EDGE_ENGAGEMENT_BASE_URL=http://engagement:8088
EDGE_FINANCE_BASE_URL=http://finance:8089
CRM_DOCUMENTS_BASE_URL=http://documents:8086
RENTALS_DOCUMENTS_BASE_URL=http://documents:8086
ENGAGEMENT_CRM_BASE_URL=http://crm:8083

# Bootstrap tenants remain explicit even when fallback is disabled.
DOCUMENTS_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
RENTALS_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
FINANCE_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
BILLING_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
WORKFLOW_CONTROL_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
ENGAGEMENT_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
WORKFLOW_RUNTIME_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
CATALOG_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
PLATFORM_CONTROL_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
SUPPORT_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
SUPPLIER_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
ACCOUNTING_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
INVENTORY_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
PROCUREMENT_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
BANKING_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
NOTIFICATION_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
FISCAL_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
