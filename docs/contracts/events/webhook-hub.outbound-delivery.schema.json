{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "erp/contracts/events/webhook-hub.outbound-delivery.schema.json",
  "title": "WebhookHubOutboundDelivery",
  "type": "object",
  "required": [
    "outboundEndpointPublicId",
    "status",
    "attemptNumber"
  ],
  "properties": {
    "outboundEndpointPublicId": {
      "type": "string",
      "format": "uuid"
    },
    "webhookEventPublicId": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "delivered", "failed", "dead_letter"]
    },
    "attemptNumber": {
      "type": "integer",
      "minimum": 1
    },
    "responseCode": {
      "type": "integer"
    },
    "lastErrorCode": {
      "type": "string"
    },
    "lastErrorMessage": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
