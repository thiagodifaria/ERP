{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erp.local/contracts/events/documents.extraction-completed.schema.json",
  "title": "Document Extraction Completed",
  "type": "object",
  "required": ["tenantSlug", "documentPublicId", "provider", "status", "payloadHash", "occurredAt"],
  "properties": {
    "tenantSlug": { "type": "string", "minLength": 1 },
    "documentPublicId": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 2 },
    "status": { "type": "string", "enum": ["completed", "failed", "manual_required"] },
    "payloadHash": { "type": "string", "minLength": 16 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "occurredAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
