# Baseline environment for the local containerized stack.

ERP_ENV=local
ERP_ALLOW_BOOTSTRAP_TENANT_FALLBACK=true
ERP_TZ=UTC
COMPOSE_PROJECT_NAME=erp
ERP_AUTH_ENFORCEMENT=local
ERP_SECURITY_LEVEL=local
ERP_REQUIRE_REQUEST_SIGNATURE=false
ERP_SECURITY_HEADERS=enabled
ERP_MAX_REQUEST_BODY_BYTES=8388608
ERP_AUDIT_LOG_REDACTION=standard
ERP_INTERNAL_MTLS_MODE=disabled
# Valores abaixo sao placeholders locais inseguros. Para gerar um .env local forte:
# ./scripts/env.sh
ERP_JWT_HS256_SECRET=change-me-unsafe-local-only-jwt
ERP_JWT_AUDIENCE=erp-api
ERP_INTERNAL_SERVICE_TOKEN=change-me-unsafe-local-only-service-token
ERP_OPENFGA_ENFORCEMENT=false

EDGE_HTTP_PORT=8080
GATEWAY_HTTP_PORT=8079
EDGE_DOWNSTREAM_TIMEOUT=1500ms
IDENTITY_HTTP_PORT=8081
WEBHOOK_HUB_HTTP_PORT=8082
CRM_HTTP_PORT=8083
CRM_DOCUMENTS_BASE_URL=http://documents:8086
WORKFLOW_CONTROL_HTTP_PORT=8084
WORKFLOW_RUNTIME_HTTP_PORT=8085
ANALYTICS_HTTP_PORT=8086
SALES_HTTP_PORT=8087
ENGAGEMENT_HTTP_PORT=8088
BILLING_HTTP_PORT=8095
FINANCE_HTTP_PORT=8092
DOCUMENTS_HTTP_PORT=8093
SIMULATION_HTTP_PORT=8094
RENTALS_HTTP_PORT=8096
CATALOG_HTTP_PORT=8097
PLATFORM_CONTROL_HTTP_PORT=8098
SUPPORT_HTTP_PORT=8099
SUPPLIER_HTTP_PORT=8100
NOTIFICATION_HTTP_PORT=8101
FISCAL_HTTP_PORT=8102
ACCOUNTING_HTTP_PORT=8103
INVENTORY_HTTP_PORT=8104
PROCUREMENT_HTTP_PORT=8105
BANKING_HTTP_PORT=8106
SEARCH_HTTP_PORT=8107
AI_GOVERNANCE_HTTP_PORT=8108
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
KEYCLOAK_PORT=8089
OPENFGA_HTTP_PORT=8090
OPENFGA_GRPC_PORT=8091
OPENFGA_PLAYGROUND_PORT=3010
# Host ports can be changed freely; the container-first scripts remap them when the default is already occupied.
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

ERP_POSTGRES_DB=erp
ERP_POSTGRES_USER=erp
ERP_POSTGRES_PASSWORD=change-me-unsafe-local-only-postgres
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-unsafe-local-only-keycloak
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-unsafe-local-only-grafana
KEYCLOAK_REALM=erp-local
KEYCLOAK_IDENTITY_CLIENT_ID=erp-identity
OPENFGA_STORE_NAME=erp-local-store
OPENFGA_STORE_ID=
OPENFGA_AUTHORIZATION_MODEL_ID=
IDENTITY_PROVIDER_DRIVER=keycloak
IDENTITY_AUTHORIZATION_DRIVER=openfga
IDENTITY_BOOTSTRAP_PASSWORD=change-me-unsafe-local-only-bootstrap
IDENTITY_EXPOSE_PASSWORD_RECOVERY_TOKEN=true
IDENTITY_MFA_ISSUER=ERP
EDGE_IDENTITY_BASE_URL=http://identity:8080
