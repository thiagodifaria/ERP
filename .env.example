# Baseline environment for the local containerized stack.
# This file will grow in Phase 1 when the first runtime services land.

ERP_ENV=local
ERP_TZ=UTC
COMPOSE_PROJECT_NAME=erp

EDGE_HTTP_PORT=8080
IDENTITY_HTTP_PORT=8081
WEBHOOK_HUB_HTTP_PORT=8082
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

ERP_POSTGRES_DB=erp
ERP_POSTGRES_USER=erp
ERP_POSTGRES_PASSWORD=erp
