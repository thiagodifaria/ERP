# Baseline environment for the local containerized stack.
# This file will grow in Phase 1 when the first runtime services land.

ERP_ENV=local
ERP_TZ=UTC
COMPOSE_PROJECT_NAME=erp

EDGE_HTTP_PORT=8080
EDGE_DOWNSTREAM_TIMEOUT=1500ms
IDENTITY_HTTP_PORT=8081
WEBHOOK_HUB_HTTP_PORT=8082
CRM_HTTP_PORT=8083
CRM_DOCUMENTS_BASE_URL=http://documents:8086
WORKFLOW_CONTROL_HTTP_PORT=8084
WORKFLOW_RUNTIME_HTTP_PORT=8085
ANALYTICS_HTTP_PORT=8086
SALES_HTTP_PORT=8087
ENGAGEMENT_HTTP_PORT=8088
FINANCE_HTTP_PORT=8092
DOCUMENTS_HTTP_PORT=8093
SIMULATION_HTTP_PORT=8094
KEYCLOAK_PORT=8089
OPENFGA_HTTP_PORT=8090
OPENFGA_GRPC_PORT=8091
OPENFGA_PLAYGROUND_PORT=3010
# Host ports can be changed freely; the container-first scripts remap them when the default is already occupied.
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

ERP_POSTGRES_DB=erp
ERP_POSTGRES_USER=erp
ERP_POSTGRES_PASSWORD=erp
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=erp-local
KEYCLOAK_IDENTITY_CLIENT_ID=erp-identity
OPENFGA_STORE_NAME=erp-local-store
IDENTITY_PROVIDER_DRIVER=keycloak
IDENTITY_AUTHORIZATION_DRIVER=openfga
IDENTITY_BOOTSTRAP_PASSWORD=Change.Me123!
IDENTITY_MFA_ISSUER=ERP
EDGE_IDENTITY_BASE_URL=http://identity:8080
EDGE_CRM_BASE_URL=http://crm:8083
EDGE_WORKFLOW_CONTROL_BASE_URL=http://workflow-control:8084
EDGE_WORKFLOW_RUNTIME_BASE_URL=http://workflow-runtime:8085
EDGE_ANALYTICS_BASE_URL=http://analytics:8086
EDGE_WEBHOOK_HUB_BASE_URL=http://webhook-hub:8082
EDGE_SALES_BASE_URL=http://sales:8087
EDGE_ENGAGEMENT_BASE_URL=http://engagement:8088
EDGE_FINANCE_BASE_URL=http://finance:8089
KEYCLOAK_BASE_URL=http://service-keycloak:8080
OPENFGA_BASE_URL=http://service-openfga:8080
CRM_POSTGRES_HOST=service-postgresql
CRM_POSTGRES_PORT=5432
CRM_POSTGRES_SSL_MODE=disable
DOCUMENTS_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
DOCUMENTS_POSTGRES_HOST=service-postgresql
DOCUMENTS_POSTGRES_PORT=5432
DOCUMENTS_POSTGRES_SSL_MODE=disable
SALES_POSTGRES_HOST=service-postgresql
SALES_POSTGRES_PORT=5432
SALES_POSTGRES_SSL_MODE=disable
FINANCE_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
FINANCE_POSTGRES_HOST=service-postgresql
FINANCE_POSTGRES_PORT=5432
FINANCE_POSTGRES_SSL_MODE=Disable
IDENTITY_POSTGRES_HOST=service-postgresql
IDENTITY_POSTGRES_PORT=5432
IDENTITY_POSTGRES_SSL_MODE=Disable
WEBHOOK_HUB_POSTGRES_HOST=service-postgresql
WEBHOOK_HUB_POSTGRES_PORT=5432
WEBHOOK_HUB_POSTGRES_SSL_MODE=disable
WORKFLOW_CONTROL_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
WORKFLOW_CONTROL_POSTGRES_HOST=service-postgresql
WORKFLOW_CONTROL_POSTGRES_PORT=5432
WORKFLOW_CONTROL_POSTGRES_SSL_MODE=disable
ENGAGEMENT_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
ENGAGEMENT_POSTGRES_HOST=service-postgresql
ENGAGEMENT_POSTGRES_PORT=5432
ENGAGEMENT_POSTGRES_SSL_MODE=disable
WORKFLOW_RUNTIME_BOOTSTRAP_TENANT_SLUG=bootstrap-ops
WORKFLOW_RUNTIME_POSTGRES_HOST=service-postgresql
WORKFLOW_RUNTIME_POSTGRES_PORT=5432
WORKFLOW_RUNTIME_POSTGRES_SSL_MODE=disable
ANALYTICS_POSTGRES_HOST=service-postgresql
ANALYTICS_POSTGRES_PORT=5432
ANALYTICS_POSTGRES_SSL_MODE=disable
SIMULATION_POSTGRES_HOST=service-postgresql
SIMULATION_POSTGRES_PORT=5432
SIMULATION_POSTGRES_SSL_MODE=disable
